# SIPREC Client Configuration File
# Copy this file to .env and modify the values as needed
# The .env file will be loaded automatically if it exists in the current directory

# Destination (SIP Server) Configuration
SIPREC_DEST_NUMBER=rec-target@srs.example.com
SIPREC_DEST_HOST=srs.example.com
SIPREC_DEST_PORT=5061

# Source (Client) Configuration
SIPREC_SRC_NUMBER=client@example.com
SIPREC_SRC_HOST=1.2.3.4
SIPREC_SRC_DISPLAY_NAME=PythonSIPRECClient

# Local Network Configuration
SIPREC_LOCAL_PORT=0

# TLS Certificate Configuration
SIPREC_CERT_FILE=client.crt
SIPREC_KEY_FILE=client.key
SIPREC_CA_FILE=ca.crt

# Audio/Media Configuration
SIPREC_AUDIO_ENCODING=PCMA/8000
SIPREC_AUDIO_FILE=/path/to/audio.wav
SIPREC_PACKET_TIME=20
SIPREC_STREAM_DURATION=60

# SIP Protocol Configuration
SIPREC_OPTIONS_PING_COUNT=0
SIPREC_OPTIONS_TARGET_URI=
SIPREC_CALL_INFO_URL=
SIPREC_SRTP_ENCRYPTION=AES_CM_128_HMAC_SHA1_80

# Stream Output Configuration
SIPREC_SAVE_STREAM1_FILE=/tmp/caller_stream.wav
SIPREC_SAVE_STREAM2_FILE=/tmp/callee_stream.wav

# Debug and Logging
SIPREC_DEBUG=false

# Packet Capture Configuration (Optional)
SIPREC_PCAP_FILE=/tmp/siprec_capture.pcapng
SIPREC_CAPTURE_INTERFACE=any
SIPREC_CAPTURE_SIP_RANGE=74.125.88.128/25
SIPREC_CAPTURE_SIP_PORT=5672
SIPREC_CAPTURE_MEDIA_RANGE=74.125.39.0/24
